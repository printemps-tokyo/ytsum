{
  "name": "@printemps-tokyo/ytsum",
  "version": "0.1.0",
  "description": "Fetch YouTube transcripts (via yt-dlp) as clean LLM-ready text. Zero-dependency CLI.",
  "type": "module",
  "license": "MIT",
  "author": "printemps.tokyo <develop@printemps.tokyo>",
  "homepage": "https://github.com/printemps-tokyo/ytsum#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/printemps-tokyo/ytsum.git"
  },
  "bugs": {
    "url": "https://github.com/printemps-tokyo/ytsum/issues"
  },
  "keywords": [
    "youtube",
    "transcript",
    "subtitles",
    "yt-dlp",
    "cli",
    "llm"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ytsum": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
